# Copy to `.env` in this directory (`apps/rfid-host`).
# Zig reads `DATABASE_URL` and `RFID_*` from the process environment first, then from
# `.env` or `../.env` relative to the current working directory when you run the binary.
# Run from `apps/rfid-host` (e.g. `zig build run -- …`) so paths match.

# --- Postgres (optional but needed for DB inserts) ---
# Same database as `apps/server` — apply `setup.sql` then `rfid_tour.sql` first.
DATABASE_URL=postgresql://USER:PASSWORD@localhost:5432/DATABASE

# Stored on each `rfid_read_event` row as `reader_id` (welcome, lidar, reader-1, …).
RFID_READER_ID=welcome

# --- Secure LLRP (TLS) — only if the reader uses secure LLRP ---
# RFID_SECURE=1
# Paths to PEM files on disk (not the PEM text itself):
# RFID_CLIENT_CERT=/path/to/client_crt.pem
# RFID_CLIENT_KEY=/path/to/client_key.pem
# RFID_ROOT_CERT=/path/to/cacert.pem
# RFID_KEY_PASSPHRASE=
# RFID_VALIDATE_PEER=1

# --- Runtime (shell / systemd, not read from .env by Zig) ---
# Required so the Zebra SDK shared libraries load:
#   export LD_LIBRARY_PATH="$(pwd)/linux64_sdk/lib:${LD_LIBRARY_PATH:-}"
