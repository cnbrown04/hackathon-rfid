# Copy to `.env` in this directory (`apps/server`).
# The server loads `apps/server/.env` via `path.join(__dirname, ".env")` — cwd does not matter.
# Scripts under `scripts/` load the same file. You can still `export` vars in the shell to override.

# --- Required ---
# PostgreSQL connection (same DB as `setup.sql` + `rfid_tour.sql`).
DATABASE_URL=postgresql://USER:PASSWORD@localhost:5432/DATABASE

# --- HTTP / WebSocket ---
# Listening port. Heroku sets PORT; locally use HTTP_PORT if you prefer.
# HTTP_PORT=3002
# PORT=3002

# --- Admin API (Bearer token = this value) ---
# Override in production — default in code is weak.
# ADMIN_PASSWORD=change-me

# --- Dev only: wipe RFID tables on server boot ---
# TRUNCATE_RFID_READ_EVENTS_ON_BOOT=true

# --- Localization (optional tuning; defaults shown in index.js) ---
# LOCALIZATION_GRID_SIZE_FT=6
# LOCALIZATION_READER_ID=localize
# LOCALIZATION_SITE_ID=rfid-lab
# LOCALIZATION_FRESH_MS=8000
# LOCALIZATION_REF_RSSI_DBM=-47
# LOCALIZATION_PATH_LOSS_N=2.2
# LOCALIZATION_REF_DISTANCE_FT=3.28084
# LOCALIZATION_MIN_DISTANCE_FT=0.2
# LOCALIZATION_MAX_DISTANCE_FT=12
